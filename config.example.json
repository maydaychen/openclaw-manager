{
  "database": {
    "host": "your-mariadb-host",
    "user": "your-db-user",
    "password": "your-db-password",
    "database": "openclaw_manager"
  },
  "aliyun": {
    "accessKeyId": "your-access-key-id",
    "accessKeySecret": "your-access-key-secret",
    "region": "cn-hangzhou"
  },
  "jwt": {
    "secret": "your-jwt-secret-key"
  },
  "backup": {
    "googleDrive": {
      "enabled": false,
      "tokenPath": "/home/your-user/.config/gogcli/token.pickle",
      "folderName": "OpenClaw备份"
    },
    "local": {
      "enabled": true,
      "path": "./backups"
    },
    "nas": {
      "enabled": false,
      "path": "/mnt/nas/openclaw-backups"
    }
  }
}
